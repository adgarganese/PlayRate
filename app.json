{
  "expo": {
    "name": "PlayRate",
    "slug": "playrate",
    "version": "1.1.2",
    "runtimeVersion": "1.1.2",
    "updates": {
      "url": "https://u.expo.dev/ce8747bd-f927-488b-b71b-9db2f74f1508",
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0
    },
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "playrate",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.playrate.app",
      "buildNumber": "6",
      "infoPlist": {
        "NSCameraUsageDescription": "Allow PlayRate to use your camera to film or photograph highlights.",
        "NSLocationWhenInUseUsageDescription": "Allow PlayRate to use your location to find courts near you.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Allow PlayRate to use your location to find courts near you.",
        "NSLocationAlwaysUsageDescription": "Allow PlayRate to use your location to find courts and runs near you.",
        "NSPhotoLibraryUsageDescription": "Allow PlayRate to access your photos to choose a profile picture or share highlights.",
        "NSMicrophoneUsageDescription": "Allow PlayRate to record audio when filming highlights.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.playrate.app",
      "versionCode": 6,
      "adaptiveIcon": {
        "backgroundColor": "#0000FF",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "softwareKeyboardLayoutMode": "resize",
      "config": {
        "googleMaps": {
          "apiKey": "${EXPO_PUBLIC_GOOGLE_MAPS_API_KEY}"
        }
      },
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-video",
      "react-native-compressor",
      "expo-secure-store",
      "expo-router",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow PlayRate to use your location to find courts near you."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#EEF1F5",
          "dark": {
            "backgroundColor": "#0B0F1A"
          }
        }
      ],
      "expo-localization",
      [
        "@sentry/react-native/expo",
        {
          "url": "https://sentry.io/",
          "organization": "playrate",
          "project": "playrate"
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#0000FF",
          "defaultChannel": "default"
        }
      ],
      "expo-updates"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "supabaseUrl": "${EXPO_PUBLIC_SUPABASE_URL}",
      "supabaseAnonKey": "${EXPO_PUBLIC_SUPABASE_ANON_KEY}",
      "googlePlacesApiKey": "${EXPO_PUBLIC_GOOGLE_PLACES_API_KEY}",
      "googleGeocodingApiKey": "${EXPO_PUBLIC_GOOGLE_GEOCODING_API_KEY}",
      "posthogApiKey": "${EXPO_PUBLIC_POSTHOG_API_KEY}",
      "posthogHost": "https://us.i.posthog.com",
      "universalLinkHost": "${EXPO_PUBLIC_UNIVERSAL_LINK_HOST}",
      "router": {},
      "eas": {
        "projectId": "ce8747bd-f927-488b-b71b-9db2f74f1508"
      }
    }
  }
}
