{
  "cli": { "version": ">= 13.2.0", "appVersionSource": "local" },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "ios": { "simulator": false }
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "ios": { "simulator": false, "image": "latest" },
      "env": { "EXPO_CACHE_DIR": "/tmp/expo-cache", "SENTRY_ALLOW_FAILURE": "true" }
    },
    "production": {
      "channel": "production",
      "ios": { "simulator": false, "image": "latest" },
      "env": { "EXPO_CACHE_DIR": "/tmp/expo-cache", "SENTRY_ALLOW_FAILURE": "true" }
    }
  },
  "submit": { "production": {} }
}
