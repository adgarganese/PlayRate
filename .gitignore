# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# --- Dependencies ---
node_modules/

# --- Build artifacts ---
build/
dist/
web-build/
.expo/
# Native (full android/ is generated on EAS; ignore nested build dirs when android exists locally)
android/app/build/
android/build/
ios/build/
*.tsbuildinfo

# --- Expo / Metro ---
expo-env.d.ts
.metro-health-check*

# --- OS files ---
.DS_Store
Thumbs.db

# --- IDE (local settings; un-ignore specific files with ! if the team shares them) ---
.vscode/
.idea/

# --- Debug logs ---
npm-debug.*
yarn-debug.*
yarn-error.*

# --- Expo / EAS: signing, certs, merge backups ---
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision
*.pem
.kotlin/

# --- Secrets, env, local credentials (app keys; never commit real values) ---
.env
.env.local
.env*.local
maps.env
.env.txt
.env.*
!.env.example
# Expo / Play local credential files (if present in project root)
credentials.json

# --- Android signing & distributable binaries (local builds) ---
*.keystore
*.apk
*.aab

# --- Project-specific ---
app-example

# Native folders are regenerated on every build via expo prebuild
/android
