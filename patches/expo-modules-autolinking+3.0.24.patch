 def maybe_generate_xcode_env_file!()
   project_directory = Pod::Config.instance.project_root
+  # Skip creating .xcode.env.local on EAS Build (working dir is read-only for this path)
+  if project_directory.to_s.include?('/Users/expo/workingdir')
+    Pod::UI.info "Skipping .xcode.env.local generation on EAS Build; using .xcode.env for NODE_BINARY"
+    return
+  end
