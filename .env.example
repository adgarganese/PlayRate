# Copy to `.env.local` (or load via your shell) and fill in values. Never commit real secrets.
# Expo exposes only variables prefixed with EXPO_PUBLIC_ to the app bundle.
# Restart the dev server after changing env files.

# --- Required for auth and API (Supabase) ---
# On EAS: use visibility "sensitive" for EXPO_PUBLIC_SUPABASE_URL and "secret" for EXPO_PUBLIC_SUPABASE_ANON_KEY (see docs/beta-launch-checklist.md).
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# --- Optional: PostHog analytics ---
# Also accepted at build time without EXPO_PUBLIC_ (see lib/config.ts): POSTHOG_API_KEY
EXPO_PUBLIC_POSTHOG_API_KEY=
EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# --- Optional: universal links / App Links (hostname only, e.g. app.playrate.com). Host AASA + Android assetlinks on that domain.
# If you use universal links: Supabase redirect should be https://<your-host>/auth/callback — same path your site serves (so the link hits your domain and AASA can hand off to the app).
# TODO (when you have a URL): Set EXPO_PUBLIC_UNIVERSAL_LINK_HOST to the hostname only, add https://YOUR_HOST/auth/callback to Supabase Auth redirect URLs, rebuild native apps.
# EXPO_PUBLIC_UNIVERSAL_LINK_HOST=

# Password reset: native builds need an HTTPS redirect for email (Gmail etc. often block playrate://). Deploy web/password-reset-bridge.html to any static host, then set this to that full URL and add it in Supabase → Auth → Redirect URLs. If unset, falls back to playrate://reset-password.
# EXPO_PUBLIC_PASSWORD_RESET_REDIRECT_URL=https://YOUR_STATIC_HOST/password-reset-bridge.html

# --- Optional: maps / Find Courts ---
# EXPO_PUBLIC_GOOGLE_MAPS_API_KEY: Android only — native Maps SDK (react-native-maps + PROVIDER_GOOGLE). iOS uses Apple Maps here; no Google Maps key on iOS unless you add ios.config.googleMaps.
# EXPO_PUBLIC_GOOGLE_PLACES_API_KEY: Places Autocomplete + Place Details (legacy REST from the device). Enable "Places API" in Google Cloud for this key.
# EXPO_PUBLIC_GOOGLE_GEOCODING_API_KEY: optional separate key for Geocoding API (court address → lat/lng). If empty, EXPO_PUBLIC_GOOGLE_PLACES_API_KEY is used — that key must then allow Geocoding API too.
# Keys are bundled (EXPO_PUBLIC_*); restrict in Google Cloud (API restrictions + Android/iOS app restrictions). REST calls send key= in the URL (mitm-visible on device).
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=
EXPO_PUBLIC_GOOGLE_PLACES_API_KEY=
EXPO_PUBLIC_GOOGLE_GEOCODING_API_KEY=

# --- Optional: Sentry error reporting ---
EXPO_PUBLIC_SENTRY_DSN=
EXPO_PUBLIC_SENTRY_ENVIRONMENT=beta

# --- EAS build only (not bundled into the app; used during native/Sentry upload steps) ---
# SENTRY_AUTH_TOKEN=
# SENTRY_DISABLE_AUTO_UPLOAD=

# --- Optional: support & legal (see lib/feedback.ts) ---
EXPO_PUBLIC_SUPPORT_EMAIL=
EXPO_PUBLIC_FEEDBACK_FORM_URL=
EXPO_PUBLIC_PRIVACY_POLICY_URL=
EXPO_PUBLIC_TERMS_URL=

# --- Optional: debugging ---
# EXPO_PUBLIC_DEBUG_ANALYTICS=true
