# PlayRate – environment variables
# Copy to .env and fill in values. Used by Expo (EXPO_PUBLIC_*) and EAS/build.

# Required: Supabase (app will not work without these)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional: PostHog (leave unset to disable analytics)
EXPO_PUBLIC_POSTHOG_API_KEY=
POSTHOG_API_KEY=
EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Optional: Google Maps / Places / Geocoding (required for courts map and address search)
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=
EXPO_PUBLIC_GOOGLE_PLACES_API_KEY=

# Optional: Sentry (leave unset to disable error reporting)
EXPO_PUBLIC_SENTRY_DSN=
EXPO_PUBLIC_SENTRY_ENVIRONMENT=beta

# Optional: Debug analytics in dev (log PostHog events to console)
# EXPO_PUBLIC_DEBUG_ANALYTICS=true

# EAS/Sentry build (when using Sentry source maps)
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=
# SENTRY_PROJECT=
